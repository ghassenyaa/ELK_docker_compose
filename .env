# Elasticsearch
ELASTIC_VERSION=8.13.4
ES_JAVA_OPTS=-Xms1g -Xmx1g
ELASTIC_PASSWORD=12345678
KIBANA_PASSWORD=12345678
ES_DATA_DIR=/usr/share/elasticsearch/data
ES_HOST=elasticsearch
ES_PORT=9200

# Kibana
KIBANA_PORT=5601

# Logstash
LOGSTASH_VERSION=8.13.4
LOGSTASH_CONFIG_FILE=/usr/share/logstash/pipeline

# Metricbeat
METRICBEAT_VERSION=8.13.4

# Fleet Server
FLEET_SERVER_PORT=8220
FLEET_SERVER_ENROLLMENT_TOKEN=your-fleet-server-enrollment-token
FLEET_URL=https://fleet-server:8220
